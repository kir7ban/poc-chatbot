# Azure AI Foundry — single project endpoint for all models
AZURE_AI_ENDPOINT=https://your-project.services.ai.azure.com/
AZURE_AI_KEY=your_azure_ai_foundry_key

# Model deployment names (set in AI Foundry portal or CLI)
CLAUDE_DEPLOYMENT=claude-3-5-sonnet
OPENAI_DEPLOYMENT=gpt-4o
GEMINI_DEPLOYMENT=gemini-1-5-flash

# Azure Cosmos DB
COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your_key;
COSMOS_DATABASE=chatbot
COSMOS_CONTAINER=conversations

PORT=3000
