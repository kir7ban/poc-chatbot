# Claude via Azure AI Foundry (East US 2 — requires Anthropic subscription access granted by Microsoft)
# Set AZURE_CLAUDE_ENDPOINT and AZURE_CLAUDE_KEY after deploying from AI Foundry portal:
# https://ai.azure.com → proj-poc-chatbot-eus2 → Model catalog → Claude → Deploy as serverless
AZURE_CLAUDE_ENDPOINT=https://claude-sonnet-4-6.eastus2.models.ai.azure.com
AZURE_CLAUDE_KEY=your_claude_endpoint_key_from_portal
CLAUDE_DEPLOYMENT=claude-sonnet-4-6

# GPT-4o via Azure OpenAI Service (East US 2)
AZURE_OPENAI_ENDPOINT=https://aoai-poc-chatbot-eus2-2b56a.openai.azure.com
AZURE_OPENAI_KEY=your_azure_openai_key
OPENAI_DEPLOYMENT=gpt-4o

# Llama 3.3 70B via Azure AI Foundry (East US 2)
AZURE_LLAMA_ENDPOINT=https://llama-3-3-70b-eus2.eastus2.models.ai.azure.com
AZURE_LLAMA_KEY=your_llama_endpoint_key
LLAMA_DEPLOYMENT=llama-3-3-70b-eus2

# Azure Cosmos DB
COSMOS_CONNECTION_STRING=AccountEndpoint=https://cosmos-poc-chatbot.documents.azure.com:443/;AccountKey=...
COSMOS_DATABASE=chatbot
COSMOS_CONTAINER=conversations

PORT=3000
