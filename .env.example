# Azure AI Services — single endpoint for all models (Anthropic, OpenAI, DeepSeek)
AZURE_AI_ENDPOINT=https://caleb-chatbot-poc-resource.cognitiveservices.azure.com
AZURE_AI_KEY=your_azure_ai_services_key
AZURE_AI_API_VERSION=2025-01-01-preview

# Azure Cosmos DB
COSMOS_CONNECTION_STRING=AccountEndpoint=https://cosmos-poc-chatbot.documents.azure.com:443/;AccountKey=...
COSMOS_DATABASE=chatbot
COSMOS_CONTAINER=conversations

PORT=3000

# Available model deployment names (set as the 'model' field in chat requests):
# Anthropic: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5
# OpenAI:    gpt-5.5 | gpt-5.4-mini
# DeepSeek:  DeepSeek-V4-Pro | DeepSeek-V3.2 | DeepSeek-V4-Flash
