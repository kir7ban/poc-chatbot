# Shared API key for all models (same caleb-chatbot-poc-resource)
AZURE_AI_KEY=your_azure_ai_services_key

# Claude via Anthropic Foundry SDK (services.ai.azure.com/anthropic)
AZURE_CLAUDE_ENDPOINT=https://caleb-chatbot-poc-resource.services.ai.azure.com/anthropic/

# GPT + DeepSeek via Azure OpenAI SDK (cognitiveservices.azure.com)
AZURE_OPENAI_ENDPOINT=https://caleb-chatbot-poc-resource.cognitiveservices.azure.com/

# Azure Cosmos DB
COSMOS_CONNECTION_STRING=AccountEndpoint=https://cosmos-poc-chatbot.documents.azure.com:443/;AccountKey=...
COSMOS_DATABASE=chatbot
COSMOS_CONTAINER=conversations

PORT=3000

# Available models:
# Claude (Anthropic SDK):  claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5
# OpenAI (Azure SDK):      gpt-5.5 | gpt-5.4-mini
# DeepSeek (Azure SDK):    DeepSeek-V4-Pro | DeepSeek-V3.2 | DeepSeek-V4-Flash
